modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "StoreApp.TUI"

[[workflows.workflow]]
name = "StoreApp.TUI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd store && python store.py"

[workflows.workflow.metadata]
outputType = "console"
